#!/bin/bash
# =================================================================
# vwn — Загрузчик модулей
# =================================================================

VWN_LIB="/usr/local/lib/vwn"

# Хуки для acme.sh (должны работать без загрузки всех модулей)
case "${1:-}" in
    "open-80")
        ufw status | grep -q inactive && exit 0
        ufw allow from any to any port 80 proto tcp comment 'ACME temp' &>/dev/null
        exit 0
        ;;
    "close-80")
        ufw status | grep -q inactive && exit 0
        ufw status numbered | grep 'ACME temp' | awk -F"[][]" '{print $2}' | sort -rn | while read -r n; do
            echo "y" | ufw delete "$n" &>/dev/null
        done
        exit 0
        ;;
    "update")
        bash <(curl -fsSL https://raw.githubusercontent.com/HnDK0/VWN-Xray-Management-Panel-debug/main/install.sh) --update
        exit 0
        ;;
    "status")
        source "$VWN_LIB/core.sh"
        loadAllModules
        _initLang
        runFullDiag
        exit 0
        ;;
    "backup")
        source "$VWN_LIB/core.sh"
        loadAllModules
        _initLang
        createBackup
        exit 0
        ;;
    "restore")
        source "$VWN_LIB/core.sh"
        loadAllModules
        _initLang
        restoreBackup
        exit 0
        ;;
    "qr")
        source "$VWN_LIB/core.sh"
        loadAllModules
        _initLang
        getQrCode
        exit 0
        ;;
esac

# Загружаем модули
source "$VWN_LIB/core.sh"
loadAllModules

# Выбор языка при первом запуске (и всегда вызываем _initLang для обновления MSG)
VWN_CONF="/usr/local/etc/xray/vwn.conf"
if [ ! -f "$VWN_CONF" ] || ! grep -q "VWN_LANG=" "$VWN_CONF" 2>/dev/null; then
    selectLang
fi
_initLang

# Системный DNS — предотвращает утечку через DNS хостера
setupSystemDNS

isRoot
menu "$@"
